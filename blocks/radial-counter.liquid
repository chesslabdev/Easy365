{%- doc -%}
  Radial Counter — public block.

  An animated circular progress counter: a number counts up from 0 to `value`
  while the SVG arc fills `value ÷ max` (or 100% when `max` is empty), triggered
  once when the block scrolls into view (see `assets/radial-counter.js`).

  FLUID & PROPORTIONAL (like ratio-callout): the block establishes a container
  (`container-type: inline-size`) capped at a `max-width` (the "Tamanho máximo"
  setting). The pill is a locked 1:1 square; the ring is a normalised SVG
  (viewBox 0–100, so stroke scales automatically); the number, label and corner
  radius are sized in `cqw` applied DIRECTLY on the leaf elements — never through
  a custom property declared on the container, because WebKit resolves container
  units stored that way to 0. So it scales smoothly down to mobile with no
  separate mobile settings, keeping the exact proportions at every width.

  The FINAL state is rendered server-side so no-JS and reduced-motion users see
  the correct number + arc; the web component resets to 0 and animates only when
  it intersects the viewport.
{%- enddoc -%}

{%- liquid
  assign bs = block.settings
  assign dmax = bs.diameter

  comment
    Ring geometry in a normalised 100×100 viewBox → stroke/radius scale with the
    SVG automatically, no per-size recalculation needed.
  endcomment
  assign sw_vb = bs.stroke_width | times: 100.0 | divided_by: dmax
  assign radius_vb = 100.0 | minus: sw_vb | divided_by: 2.0
  assign circ = radius_vb | times: 6.28318530718

  if bs.max > 0
    assign fill = bs.value | times: 1.0 | divided_by: bs.max
    if fill > 1
      assign fill = 1
    endif
  else
    assign fill = 1
  endif
  assign dash = circ | times: fill
  assign offset_final = circ | minus: dash

  comment Text + radius as a percentage of the (max) circle width → cqw. endcomment
  assign value_cqw = bs.value_font_size | times: 100.0 | divided_by: dmax
  assign label_cqw = bs.label_font_size | times: 100.0 | divided_by: dmax
  assign radius_cqw = bs.border_radius | times: 100.0 | divided_by: dmax

  assign aria = bs.value | append: ''
  if bs.unit_label != blank
    assign aria = aria | append: ' ' | append: bs.unit_label
  endif
-%}

<radial-counter
  class="radial-counter{% if bs.inherit_color_scheme == false %} color-{{ bs.color_scheme }}{% endif %}"
  style="
    --rc-max: {{ dmax }}px;
    --rc-track: {% if bs.track_color != blank %}{{ bs.track_color }}{% else %}rgb(var(--color-foreground-rgb) / 0.18){% endif %};
    --rc-progress: {% if bs.progress_color != blank %}{{ bs.progress_color }}{% else %}rgb(var(--color-primary)){% endif %};
  "
  data-target="{{ bs.value }}"
  {% if bs.max > 0 %}data-max="{{ bs.max }}"{% endif %}
  data-duration="{{ bs.duration_ms }}"
  {{ block.shopify_attributes }}
>
  {%- comment -%}
    cqw is applied directly here (radius inline on the pill, font-size inline on
    the value/label) so it resolves against `.radial-counter` in every browser.
  {%- endcomment -%}
  <div
    class="radial-counter__pill"
    style="
      border-radius: {{ radius_cqw }}cqw;
      border: {{ bs.border_width }}px {{ bs.border }} rgb(var(--color-border-rgb) / {{ bs.border_opacity | divided_by: 100.0 }});
    "
    role="img"
    aria-label="{{ aria | escape }}"
  >
    <svg class="radial-counter__ring" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
      <circle class="radial-counter__track" cx="50" cy="50" r="{{ radius_vb }}" fill="none" stroke-width="{{ sw_vb }}"></circle>
      <circle
        class="radial-counter__arc"
        ref="arc"
        cx="50"
        cy="50"
        r="{{ radius_vb }}"
        fill="none"
        stroke-width="{{ sw_vb }}"
        stroke-linecap="round"
        transform="rotate(-90 50 50)"
        style="stroke-dasharray: {{ circ }}; stroke-dashoffset: {{ offset_final }};"
      ></circle>
    </svg>
    <span class="radial-counter__content">
      <span class="radial-counter__value" ref="value" style="font-size: {{ value_cqw }}cqw;">{{ bs.value }}</span>
      {%- if bs.unit_label != blank -%}
        <span class="radial-counter__label" style="font-size: {{ label_cqw }}cqw;">{{ bs.unit_label }}</span>
      {%- endif -%}
    </span>
  </div>
</radial-counter>

<script src="{{ 'radial-counter.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% stylesheet %}
  .radial-counter {
    /* Block root: real box (NOT display:contents) so it can be the container
       AND be observed by IntersectionObserver. Fluid up to the max width. */
    display: block;
    inline-size: 100%;
    max-inline-size: var(--rc-max);
    margin-inline: auto;
    container-type: inline-size;
  }

  .radial-counter__pill {
    position: relative;
    box-sizing: border-box;
    inline-size: 100%;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    background: var(--color-background);
    color: var(--color-foreground);
    box-shadow: 0 2px 6px rgb(0 0 0 / 6%), 0 1px 2px rgb(0 0 0 / 4%);
  }

  .radial-counter__ring,
  .radial-counter__content {
    grid-area: 1 / 1;
  }

  .radial-counter__ring {
    display: block;
    inline-size: 100%;
    block-size: 100%;
  }

  .radial-counter__track {
    stroke: var(--rc-track);
  }

  .radial-counter__arc {
    stroke: var(--rc-progress);
  }

  .radial-counter__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1;
    text-align: center;
    pointer-events: none;
  }

  .radial-counter__value {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .radial-counter__label {
    margin-top: 0.3em;
    letter-spacing: 0.08em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Radial counter",
  "tag": null,
  "settings": [
    { "type": "header", "content": "Conteúdo" },
    { "type": "number", "id": "value", "label": "Valor (conta até)", "default": 2 },
    { "type": "number", "id": "max", "label": "Meta (preenche o anel)", "info": "Deixe vazio para o anel preencher 100%." },
    { "type": "text", "id": "unit_label", "label": "Rótulo (unidade)", "default": "doses" },

    { "type": "header", "content": "Aparência" },
    { "type": "checkbox", "id": "inherit_color_scheme", "label": "t:settings.inherit_color_scheme", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-1", "visible_if": "{{ block.settings.inherit_color_scheme == false }}" },
    { "type": "paragraph", "content": "Deixe uma cor vazia para herdar do esquema de cores." },
    { "type": "color", "id": "track_color", "label": "Cor da trilha do anel" },
    { "type": "color", "id": "progress_color", "label": "Cor do progresso" },
    { "type": "range", "id": "value_font_size", "label": "Tamanho do número", "min": 12, "max": 96, "step": 1, "unit": "px", "default": 24, "info": "Referência no tamanho máximo; escala proporcionalmente." },
    { "type": "range", "id": "label_font_size", "label": "Tamanho do rótulo", "min": 8, "max": 40, "step": 1, "unit": "px", "default": 11 },

    { "type": "header", "content": "Anel" },
    { "type": "range", "id": "diameter", "label": "Tamanho máximo (largura)", "min": 60, "max": 320, "step": 5, "unit": "px", "default": 130, "info": "O componente escala com a largura da coluna até este teto." },
    { "type": "range", "id": "stroke_width", "label": "Espessura do anel", "min": 2, "max": 24, "step": 1, "unit": "px", "default": 10, "info": "Referência no tamanho máximo." },
    { "type": "range", "id": "duration_ms", "label": "Duração da animação", "min": 400, "max": 4000, "step": 100, "unit": "ms", "default": 1500 },

    { "type": "header", "content": "Borda" },
    { "type": "select", "id": "border", "label": "t:settings.style", "options": [ { "value": "none", "label": "t:options.none" }, { "value": "solid", "label": "t:options.solid" }, { "value": "dashed", "label": "Tracejado" }, { "value": "dotted", "label": "t:options.dotted" } ], "default": "none" },
    { "type": "range", "id": "border_width", "label": "t:settings.thickness", "min": 0, "max": 12, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "border_opacity", "label": "t:settings.opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 100 },
    { "type": "range", "id": "border_radius", "label": "t:settings.border_radius", "min": 0, "max": 200, "step": 2, "unit": "px", "default": 200, "info": "Proporcional; valor alto = círculo." }
  ],
  "presets": [
    {
      "name": "Radial counter",
      "settings": {
        "value": 2,
        "max": 8,
        "unit_label": "doses",
        "inherit_color_scheme": false,
        "color_scheme": "scheme-1",
        "diameter": 130,
        "stroke_width": 10,
        "value_font_size": 24,
        "label_font_size": 11,
        "duration_ms": 1500,
        "border_radius": 200
      }
    }
  ]
}
{% endschema %}
