{%- doc -%}
  Renders one 32px social-proof avatar for the Eazy365 hero.

  @param {object} image - The avatar image (from an image_picker setting).

  @example
  {% render 'eazy-hero-avatar', image: section.settings.avatar_1 %}
{%- enddoc -%}

{{
  image
  | image_url: width: 64
  | image_tag:
    loading: 'lazy',
    decoding: 'async',
    width: 32,
    height: 32,
    alt: '',
    class: 'eazy-hero__avatar'
}}
