    { "type": "range", "id": "autoplay_speed", "label": "t:settings.speed", "min": 3, "max": 7, "step": 1, "unit": "s", "default": 5, "visible_if": "{{ section.settings.autoplay }}" },
    { "type": "header", "content": "t:content.padding" },
