{%- comment -%}
  Marquee strip — a global, brand-neutral scrolling "ticker" bar (the Figma "régua fio").

  ARCHITECTURE (see .fractal/instructions/standards/horizon-theme.instruction.md):
  - Chrome reuses NATIVE Horizon mechanisms instead of hand-rolled CSS:
    • Width (page-width / full-width) → the native `.section` grid + `section--{width}`
      modifier (base.css). The bar is the grid's child, so it lands in the centered
      page column or spans full-bleed — the width system the theme warns not to rewrite.
    • Color → the native `color-{scheme}` class on the bar exposes `--color-background`
      / `--color-foreground`. Painted on the bar itself (not `.section-background`), so it
      works inside the header group, where the section-background layer is suppressed.
    • Padding → `spacing-style` snippet. Radius/border → `border-style` + `border-override`.
    • Margin → inline `margin-*` from settings (no native margin snippet exists).
  - Reuses the native MARQUEE engine: renders the exact `<marquee-component>` DOM contract
    `assets/marquee.js` requires (refs wrapper/content/marqueeItems + data-speed-factor),
    so infinite scroll, speed calc, hover-pause and reduced-motion all come from native JS.
  - The marquee layout CSS is mirrored here on purpose: the native `sections/marquee.liquid`
    stylesheet only loads when THAT section is present, so a standalone strip needs it.
  - Blocks: native `text` / `image` / `icon` / `logo` / `_divider` compose the ticker.
  - Mobile-first: ships the "Mobile" spacing controls via the `mobile-spacing` snippet.
{%- endcomment -%}

<script src="{{ 'marquee.js' | asset_url }}" type="module" fetchpriority="low"></script>

{%- liquid
  assign s = section.settings
-%}

<div
  class="section section--{{ s.section_width }} marquee-strip-section"
  style="
    margin-block: {{ s['margin-block-start'] | default: 0 }}px {{ s['margin-block-end'] | default: 0 }}px;
    margin-inline: {{ s['margin-inline-start'] | default: 0 }}px {{ s['margin-inline-end'] | default: 0 }}px;
  "
>
  <marquee-component
    class="marquee-strip spacing-style border-style color-{{ s.color_scheme }}{% if s.custom_mobile_padding %} mobile-spacing-{{ section.id }}{% endif %}"
    style="
      {%- render 'spacing-style', settings: s %}
      {%- render 'border-override', settings: s %}
      {% render 'gap-style', value: s.gap_between_elements, name: 'marquee-gap' %}
      --marquee-direction: {{ s.movement_direction }};
      --marquee-strip-min-height: {{ s.min_height }}px;
    "
    data-speed-factor="{{ s.speed_factor }}"
    data-movement-direction="{{ s.movement_direction }}"
  >
    <div class="marquee__wrapper" ref="wrapper">
      <div class="marquee__content" ref="content">
        <div class="marquee__repeated-items" ref="marqueeItems[]">
          {% content_for 'blocks' %}
        </div>
      </div>
    </div>
  </marquee-component>
</div>

{% render 'mobile-spacing', settings: s, id: section.id %}

{% stylesheet %}
  /* Strip host (the marquee-component) — the rounded accent bar. Color comes from the
     chosen color scheme via the color-{scheme} class on this element. */
  .marquee-strip {
    display: flex;
    align-items: center;
    width: 100%;
    overflow: hidden;
    background: var(--color-background);
    color: var(--color-foreground);
    min-height: var(--marquee-strip-min-height, 20px);
  }

  /* Force legible ticker text/marks over the accent bar, regardless of block color settings. */
  .marquee-strip :is(p, span, a, h1, h2, h3, h4, h5, h6),
  .marquee-strip :is(svg, .icon) {
    color: var(--color-foreground);
  }

  /* Native marquee layout (mirrored from sections/marquee.liquid so the strip works standalone). */
  .marquee__wrapper {
    display: flex;
    gap: var(--marquee-gap);
    width: fit-content;
    white-space: nowrap;
  }

  .marquee__content {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
  }

  .marquee__content :is(p, h1, h2, h3, h4, h5, h6) {
    white-space: nowrap;
  }

  .marquee__content .marquee__repeated-items * {
    max-width: none;
  }

  .marquee__repeated-items {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
    align-items: center;
    justify-content: center;
  }

  .marquee__repeated-items > * {
    align-content: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .marquee-strip:not([data-disabled]) .marquee__wrapper {
      animation: marquee-motion var(--marquee-speed) linear infinite var(--marquee-direction);
    }
  }

  @keyframes marquee-motion {
    to {
      transform: translate3d(calc(-50% - (var(--marquee-gap) / 2)), 0, 0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Marquee strip",
  "blocks": [
    { "type": "text" },
    { "type": "image" },
    { "type": "icon" },
    { "type": "logo" },
    { "type": "_divider" }
  ],
  "settings": [
    { "type": "header", "content": "t:content.layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "movement_direction",
      "label": "t:settings.motion_direction",
      "options": [
        { "value": "reverse", "label": "t:options.forward" },
        { "value": "normal", "label": "t:options.reverse" }
      ],
      "default": "normal"
    },
    { "type": "range", "id": "speed_factor", "label": "t:settings.speed", "min": 5, "max": 60, "step": 1, "default": 25 },
    { "type": "range", "id": "gap_between_elements", "label": "t:settings.gap", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 48 },

    { "type": "header", "content": "t:content.appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-3" },
    { "type": "range", "id": "min_height", "label": "Altura mínima", "min": 12, "max": 120, "step": 2, "unit": "px", "default": 20 },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.borders",
      "options": [
        { "value": "none", "label": "t:options.none" },
        { "value": "solid", "label": "t:options.solid" }
      ],
      "default": "none"
    },
    { "type": "range", "id": "border_width", "min": 0, "max": 10, "step": 1, "unit": "px", "label": "t:settings.border_width", "default": 1, "visible_if": "{{ section.settings.border != 'none' }}" },
    { "type": "range", "id": "border_opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "t:settings.border_opacity", "default": 100, "visible_if": "{{ section.settings.border != 'none' }}" },
    { "type": "range", "id": "border_radius", "label": "t:settings.border_radius", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 14 },

    { "type": "header", "content": "t:content.padding" },
    { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-start", "label": "t:settings.left", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end", "label": "t:settings.right", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },

    { "type": "header", "content": "Margem" },
    { "type": "range", "id": "margin-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin-inline-start", "label": "t:settings.left", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin-inline-end", "label": "t:settings.right", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },

    { "type": "header", "content": "Mobile" },
    { "type": "checkbox", "id": "custom_mobile_padding", "label": "Espaçamento separado no mobile", "default": false },
    { "type": "range", "id": "padding-block-start-mobile", "label": "Superior (mobile)", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0, "visible_if": "{{ section.settings.custom_mobile_padding }}" },
    { "type": "range", "id": "padding-block-end-mobile", "label": "Inferior (mobile)", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0, "visible_if": "{{ section.settings.custom_mobile_padding }}" },
    { "type": "range", "id": "padding-inline-start-mobile", "label": "Esquerda (mobile)", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0, "visible_if": "{{ section.settings.custom_mobile_padding }}" },
    { "type": "range", "id": "padding-inline-end-mobile", "label": "Direita (mobile)", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0, "visible_if": "{{ section.settings.custom_mobile_padding }}" }
  ],
  "presets": [
    {
      "name": "Marquee strip",
      "category": "t:categories.text",
      "settings": {
        "section_width": "page-width",
        "movement_direction": "normal",
        "speed_factor": 25,
        "gap_between_elements": 48,
        "color_scheme": "scheme-3",
        "border_radius": 14,
        "min_height": 20
      },
      "blocks": {
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>Zero açúcar. Adoçado naturalmente com Stevia.</p>",
            "type_preset": "custom",
            "font": "var(--font-accent--family)",
            "font_size": "0.75rem",
            "line_height": "tight",
            "letter_spacing": "tight",
            "case": "none",
            "wrap": "nowrap",
            "width": "fit-content"
          }
        },
        "text_2": {
          "type": "text",
          "settings": {
            "text": "<p>Praticidade para levar na mala ou mochila.</p>",
            "type_preset": "custom",
            "font": "var(--font-accent--family)",
            "font_size": "0.75rem",
            "line_height": "tight",
            "letter_spacing": "tight",
            "case": "none",
            "wrap": "nowrap",
            "width": "fit-content"
          }
        }
      },
      "block_order": ["text_1", "text_2"]
    }
  ]
}
{% endschema %}
