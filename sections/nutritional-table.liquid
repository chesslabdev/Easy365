{%- comment -%}
  Nutritional Table — banner do produto + card "Tabela Nutricional".
  Esquerda: selo + headline + descrição + "12 kcal". Direita: card laranja com a
  tabela (NUTRIENTE / QTD POR DOSE / %VD) montada por blocos `_nutritional-row`.

  Arquitetura (Decorator): o conteúdo é capturado em `children` (incluindo
  {% content_for 'blocks' %} das linhas) e renderizado pelo MOTOR BASE de seção
  ({% render 'section' %}), herdando largura (section_width), color scheme, background,
  overlay, borda/raio e padding — sem editar o arquivo nativo. O schema replica as
  settings do motor base (o contrato do snippet).

  Responsivo: 2 colunas no desktop, empilhado no mobile (≤749px). Tipografia fluida
  via clamp() para a tabela permanecer legível; banner mantém o aspect-ratio do Figma.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
-%}

{%- capture children -%}
  <div class="nt" style="--nt-bg: {{ s.bg_color }}; --nt-accent: {{ s.accent_color }};">
    {%- comment -%} ===== Banner ===== {%- endcomment -%}
    <div class="nt__banner">
      {%- if s.banner_image != blank -%}
        {{ s.banner_image | image_url: width: 1600 | image_tag: loading: 'lazy', decoding: 'async', sizes: '(min-width: 750px) 84vw, 100vw', widths: '480, 768, 1100, 1440, 1600', alt: s.banner_alt }}
      {%- else -%}
        <img src="{{ 'nutritional-banner.jpg' | asset_url }}" alt="{{ s.banner_alt | escape }}" width="1546" height="720" loading="lazy" decoding="async">
      {%- endif -%}
    </div>

    {%- comment -%} ===== Card azul ===== {%- endcomment -%}
    <div class="nt__card">
      <div class="nt__grid">
        {%- comment -%} Coluna esquerda — intro {%- endcomment -%}
        <div class="nt__intro">
          {%- if s.label != blank -%}<p class="nt__label">{{ s.label }}</p>{%- endif -%}
          {%- if s.heading != blank -%}<h2 class="nt__heading">{{ s.heading | newline_to_br }}</h2>{%- endif -%}
          {%- if s.description != blank -%}<p class="nt__desc">{{ s.description }}</p>{%- endif -%}
          <div class="nt__kcal">
            <span class="nt__kcal-value">{{ s.kcal_value }}</span>
            <span class="nt__kcal-unit">{{ s.kcal_unit }}</span>
          </div>
          {%- if s.kcal_caption != blank -%}<p class="nt__kcal-caption">{{ s.kcal_caption }}</p>{%- endif -%}
        </div>

        {%- comment -%} Coluna direita — tabela laranja {%- endcomment -%}
        <div class="nt__table">
          <div class="nt__thead">
            <span class="nt__h nt__h--name"><span class="nt__pill">{{ s.head_name }}</span></span>
            <span class="nt__h nt__h--qty"><span class="nt__pill">{{ s.head_qty }}</span></span>
            <span class="nt__h nt__h--vd"><span class="nt__pill">{{ s.head_vd }}</span></span>
          </div>

          {% content_for 'blocks' %}

          {%- if s.footnote != blank -%}
            <p class="nt__footnote">{{ s.footnote }}</p>
          {%- endif -%}
        </div>
      </div>

      <img class="nt__wave" src="{{ 'nutritional-wave.svg' | asset_url }}" alt="" aria-hidden="true" width="1804" height="507" loading="lazy">
    </div>
  </div>
{%- endcapture -%}

{% render 'section', section: section, children: children %}

{% stylesheet %}
.nt {
  --nt-on-accent: #fefffc;
  --nt-font: "Helvetica Neue", Helvetica, Arial, sans-serif;
  --nt-overlap: clamp(36px, 6vw, 100px);

  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-family: var(--nt-font);
}

/* ===== Banner ===== */
.nt__banner {
  position: relative;
  z-index: 2;
  width: 84%;
  max-width: 1100px;
  aspect-ratio: 1240 / 413;
  margin-bottom: calc(-1 * var(--nt-overlap));
  border-radius: clamp(12px, 1.5vw, 22px);
  overflow: hidden;
  box-shadow: 0 12px 24px -4px rgba(0, 0, 0, 0.18), 0 4px 8px -2px rgba(0, 0, 0, 0.10);
}
.nt__banner img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* ===== Card azul ===== */
.nt__card {
  position: relative;
  z-index: 1;
  width: 100%;
  background: var(--nt-bg, #1a388d);
  border-radius: clamp(14px, 1.6vw, 22px);
  padding: calc(var(--nt-overlap) + clamp(32px, 5vw, 72px)) clamp(20px, 5vw, 96px) clamp(40px, 6vw, 72px);
  overflow: hidden;
  box-shadow: 0 12px 24px -4px rgba(0, 0, 0, 0.10), 0 4px 8px -2px rgba(0, 0, 0, 0.06);
}

.nt__grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(260px, 420px) 1fr;
  gap: clamp(24px, 5vw, 80px);
  align-items: start;
}

/* ===== Intro (esquerda) ===== */
.nt__intro {
  display: flex;
  flex-direction: column;
  gap: clamp(10px, 1.2vw, 16px);
  color: var(--nt-on-accent);
}
.nt__label {
  margin: 0;
  color: var(--nt-accent, #ff4c24);
  font-family: ui-monospace, "Courier New", monospace;
  font-size: clamp(10px, 1vw, 12px);
  letter-spacing: 0.14em;
  text-transform: uppercase;
}
.nt__heading {
  margin: 0;
  font-weight: 700;
  font-size: clamp(26px, 3.2vw, 36px);
  line-height: 1.05;
  letter-spacing: -0.015em;
}
.nt__desc {
  margin: 0;
  font-weight: 400;
  font-size: clamp(15px, 1.6vw, 19px);
  line-height: 1.45;
  opacity: 0.75;
}
.nt__kcal {
  display: flex;
  align-items: flex-start;
  gap: clamp(4px, 0.5vw, 8px);
  padding-top: clamp(12px, 2vw, 24px);
}
.nt__kcal-value {
  font-weight: 700;
  font-style: italic;
  font-size: clamp(56px, 7vw, 96px);
  line-height: 0.9;
  letter-spacing: -0.03em;
}
.nt__kcal-unit {
  font-weight: 500;
  font-size: clamp(16px, 2vw, 24px);
  line-height: 1.15;
}
.nt__kcal-caption {
  margin: 0;
  font-size: clamp(13px, 1.3vw, 16px);
  opacity: 0.6;
}

/* ===== Tabela laranja (direita) ===== */
.nt__table {
  --col-qty: clamp(60px, 8vw, 110px);
  --col-vd: clamp(48px, 6vw, 120px);
  --col-gap: clamp(8px, 1.5vw, 16px);

  background: linear-gradient(180deg, var(--nt-accent, #ff4c24) 0%, #fd927a 100%);
  border-radius: clamp(12px, 1.4vw, 14px);
  padding: clamp(20px, 2.5vw, 32px);
  color: var(--nt-on-accent);
}

.nt__thead {
  display: flex;
  align-items: center;
  gap: var(--col-gap);
  padding-bottom: clamp(8px, 1.2vw, 12px);
}
.nt__h--name { flex: 1; min-width: 0; }
.nt__h--qty { width: var(--col-qty); display: flex; justify-content: flex-end; }
.nt__h--vd { width: var(--col-vd); display: flex; justify-content: flex-end; }
.nt__pill {
  display: inline-flex;
  align-items: center;
  background: #000100;
  color: var(--nt-on-accent);
  font-weight: 700;
  font-size: clamp(10px, 1.1vw, 13px);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: clamp(5px, 0.6vw, 8px) clamp(8px, 1vw, 12px);
  border-radius: 999px;
  white-space: nowrap;
}

.nt__footnote {
  margin: 0;
  padding-top: clamp(12px, 1.4vw, 16px);
  margin-top: clamp(6px, 0.8vw, 10px);
  border-top: 1px solid rgba(255, 255, 255, 0.20);
  font-size: clamp(11px, 1.1vw, 13px);
  line-height: 1.4;
  letter-spacing: 0.02em;
  opacity: 0.85;
}

/* ===== Onda decorativa ===== */
.nt__wave {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 70%;
  max-width: 900px;
  height: auto;
  opacity: 0.18;
  mix-blend-mode: overlay;
  pointer-events: none;
  z-index: 0;
}

/* ===== Mobile (≤749px) ===== */
@media (max-width: 749px) {
  .nt__banner { width: 100%; }
  .nt__grid { grid-template-columns: 1fr; gap: clamp(24px, 6vw, 40px); }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Tabela nutricional",
  "tag": "section",
  "class": "section-wrapper",
  "blocks": [{ "type": "_nutritional-row" }],
  "settings": [
    { "type": "header", "content": "Imagem" },
    { "type": "image_picker", "id": "banner_image", "label": "Imagem do banner" },
    { "type": "text", "id": "banner_alt", "label": "Texto alternativo", "default": "Pessoa preparando o Eazy" },

    { "type": "header", "content": "Intro" },
    { "type": "text", "id": "label", "label": "Selo", "default": "TABELA NUTRICIONAL" },
    { "type": "textarea", "id": "heading", "label": "Título", "default": "Sem rodeios.\nSem letra miúda." },
    { "type": "textarea", "id": "description", "label": "Descrição", "default": "Os valores abaixo correspondem a uma porção de 2g (1 squeeze) em 200ml de água. Cada frasco rende 25 doses." },
    { "type": "text", "id": "kcal_value", "label": "Destaque (número)", "default": "12" },
    { "type": "text", "id": "kcal_unit", "label": "Destaque (unidade)", "default": "kcal" },
    { "type": "text", "id": "kcal_caption", "label": "Legenda do destaque", "default": "Valor energético por porção · ~0,6% VD" },

    { "type": "header", "content": "Tabela" },
    { "type": "text", "id": "head_name", "label": "Cabeçalho 1", "default": "NUTRIENTE" },
    { "type": "text", "id": "head_qty", "label": "Cabeçalho 2", "default": "QTD POR DOSE" },
    { "type": "text", "id": "head_vd", "label": "Cabeçalho 3", "default": "%VD*" },
    { "type": "textarea", "id": "footnote", "label": "Nota de rodapé", "default": "* Valores diários (VD) com base em uma dieta de 2.000 kcal. Seus valores podem ser diferentes." },

    { "type": "header", "content": "Cores do card" },
    { "type": "color", "id": "bg_color", "label": "Fundo do card", "default": "#1a388d" },
    { "type": "color", "id": "accent_color", "label": "Cor de destaque / tabela", "default": "#ff4c24" },

    { "type": "header", "content": "t:content.layout" },
    {
      "type": "select", "id": "content_direction", "label": "t:settings.direction",
      "options": [
        { "value": "column", "label": "t:options.vertical" },
        { "value": "row", "label": "t:options.horizontal" }
      ],
      "default": "column"
    },
    {
      "type": "select", "id": "horizontal_alignment_flex_direction_column", "label": "t:settings.alignment",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction != 'row' }}"
    },
    {
      "type": "select", "id": "vertical_alignment_flex_direction_column", "label": "t:settings.position",
      "options": [
        { "value": "flex-start", "label": "t:options.top" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.bottom" },
        { "value": "space-between", "label": "t:options.space_between" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.content_direction == 'column' }}"
    },
    { "type": "range", "id": "gap", "label": "t:settings.gap", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },

    { "type": "header", "content": "t:content.size" },
    {
      "type": "select", "id": "section_width", "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "select", "id": "section_height", "label": "t:settings.height",
      "options": [
        { "value": "", "label": "t:options.auto" },
        { "value": "small", "label": "t:options.small" },
        { "value": "medium", "label": "t:options.medium" },
        { "value": "large", "label": "t:options.large" },
        { "value": "full-screen", "label": "t:options.full_screen" },
        { "value": "custom", "label": "t:options.custom" }
      ],
      "default": ""
    },
    { "type": "range", "id": "section_height_custom", "label": "t:settings.custom_height", "min": 0, "max": 100, "step": 1, "default": 50, "unit": "%", "visible_if": "{{ section.settings.section_height == 'custom' }}" },

    { "type": "header", "content": "t:content.appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-1" },
    {
      "type": "select", "id": "background_media", "label": "t:settings.background_media",
      "options": [
        { "value": "none", "label": "t:options.none" },
        { "value": "image", "label": "t:options.image" },
        { "value": "video", "label": "t:options.video" }
      ],
      "default": "none"
    },
    { "type": "video", "id": "video", "label": "t:settings.video", "visible_if": "{{ section.settings.background_media == 'video' }}" },
    {
      "type": "select", "id": "video_position", "label": "t:settings.video_position",
      "options": [
        { "value": "cover", "label": "t:options.cover" },
        { "value": "contain", "label": "t:options.contain" }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_media == 'video' }}"
    },
    { "type": "image_picker", "id": "background_image", "label": "t:settings.image", "visible_if": "{{ section.settings.background_media == 'image' }}" },
    {
      "type": "select", "id": "background_image_position", "label": "t:settings.image_position",
      "options": [
        { "value": "cover", "label": "t:options.cover" },
        { "value": "fit", "label": "t:options.fit" }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_media == 'image' }}"
    },
    {
      "type": "select", "id": "border", "label": "t:settings.borders",
      "options": [
        { "value": "none", "label": "t:options.none" },
        { "value": "solid", "label": "t:options.solid" }
      ],
      "default": "none"
    },
    { "type": "range", "id": "border_width", "min": 0, "max": 10, "step": 0.5, "unit": "px", "label": "t:settings.border_width", "default": 1, "visible_if": "{{ section.settings.border != 'none' }}" },
    { "type": "range", "id": "border_opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "t:settings.border_opacity", "default": 100, "visible_if": "{{ section.settings.border != 'none' }}" },
    { "type": "range", "id": "border_radius", "label": "t:settings.border_radius", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "checkbox", "id": "toggle_overlay", "label": "t:settings.background_overlay" },
    { "type": "color", "id": "overlay_color", "label": "t:settings.overlay_color", "alpha": true, "default": "#00000026", "visible_if": "{{ section.settings.toggle_overlay }}" },
    {
      "type": "select", "id": "overlay_style", "label": "t:settings.overlay_style",
      "options": [
        { "value": "solid", "label": "t:options.solid" },
        { "value": "gradient", "label": "t:options.gradient" }
      ],
      "default": "solid",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select", "id": "gradient_direction", "label": "t:settings.gradient_direction",
      "options": [
        { "value": "to top", "label": "t:options.up" },
        { "value": "to bottom", "label": "t:options.down" }
      ],
      "default": "to top",
      "visible_if": "{{ section.settings.toggle_overlay and section.settings.overlay_style == 'gradient' }}"
    },

    { "type": "header", "content": "t:content.padding" },
    { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 48 }
  ],
  "presets": [
    {
      "name": "Tabela nutricional",
      "category": "t:categories.text",
      "settings": {
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "center",
        "gap": 0,
        "section_width": "page-width",
        "section_height": "",
        "color_scheme": "",
        "border": "none",
        "border_radius": 0,
        "padding-block-start": 48,
        "padding-block-end": 48
      },
      "blocks": [
        { "type": "_nutritional-row", "settings": { "name": "Valor energético", "qty": "12 kcal", "vd": "0,6%" } },
        { "type": "_nutritional-row", "settings": { "name": "Carboidratos", "qty": "0,8 g", "vd": "0,3%" } },
        { "type": "_nutritional-row", "settings": { "name": "└ dos quais açúcares", "qty": "0 g", "vd": "—" } },
        { "type": "_nutritional-row", "settings": { "name": "Proteínas", "qty": "0 g", "vd": "—" } },
        { "type": "_nutritional-row", "settings": { "name": "Gorduras totais", "qty": "0 g", "vd": "—" } },
        { "type": "_nutritional-row", "settings": { "name": "Sódio", "qty": "210 mg", "vd": "9%" } },
        { "type": "_nutritional-row", "settings": { "name": "Magnésio Bisglicinato", "qty": "63 mg", "vd": "20%" } },
        { "type": "_nutritional-row", "settings": { "name": "Potássio", "qty": "120 mg", "vd": "3%" } },
        { "type": "_nutritional-row", "settings": { "name": "Cálcio", "qty": "80 mg", "vd": "8%" } },
        { "type": "_nutritional-row", "settings": { "name": "Zinco", "qty": "2,5 mg", "vd": "23%" } }
      ]
    }
  ]
}
{% endschema %}
